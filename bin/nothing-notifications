        letter-spacing: 2px;
    }
    .row-divider-inline {
        background-color: rgba(255, 255, 255, 0.04);
    }

    /* Notification row — flat, no card */
    .notif-row {
        background: transparent;
        border: none;
        border-radius: 0;
    }
    .notif-row:hover {
        background-color: rgba(255, 255, 255, 0.02);
        border-radius: 10px;
    }

    /* Notification text */
    .notif-app {
        font-family: "JetBrains Mono", monospace;
        font-weight: 700;
        font-size: 9px;
        color: rgba(255, 255, 255, 0.55);
        letter-spacing: 1.5px;
    }
    .notif-sep {
        font-family: "JetBrains Mono", monospace;
        font-size: 10px;
        color: rgba(255, 255, 255, 0.20);
    }
    .notif-time {
        font-family: "JetBrains Mono", monospace;
        font-weight: 600;
        font-size: 9px;
        color: rgba(255, 255, 255, 0.30);
        letter-spacing: 1px;
    }
    .notif-title {
        font-family: "Inter", sans-serif;
        font-weight: 600;
        font-size: 13px;
        color: #FFFFFF;
        letter-spacing: 0.1px;
        margin-top: 2px;
    }
    .notif-body {
        font-family: "Inter", sans-serif;
        font-weight: 400;
        font-size: 11px;
        color: rgba(255, 255, 255, 0.55);
        margin-top: 2px;
    }

    /* Action pills */
    .action-pill, .action-pill-accent {
        font-family: "JetBrains Mono", monospace;
        font-weight: 700;
        font-size: 9px;
        letter-spacing: 1.5px;
        padding: 6px 14px;
        border-radius: 14px;
        min-height: 0;
        transition: all 120ms ease;
    }
    .action-pill {
        background-color: rgba(255, 255, 255, 0.06);
        color: rgba(255, 255, 255, 0.85);
        border: 1px solid rgba(255, 255, 255, 0.08);
    }
    .action-pill:hover {
        background-color: rgba(255, 255, 255, 0.10);
        color: #FFFFFF;
        border-color: rgba(255, 255, 255, 0.16);
    }
    .action-pill-accent {
        background-color: rgba(255, 45, 45, 0.10);
        color: #FF2D2D;
        border: 1px solid rgba(255, 45, 45, 0.30);
    }
    .action-pill-accent:hover {
        background-color: #FF2D2D;
        color: #FFFFFF;
        border-color: #FF2D2D;
    }
    """

    def __init__(self):
        super().__init__(
            application_id="tech.nothing.notifications",
            flags=Gio.ApplicationFlags.HANDLES_COMMAND_LINE,
        )
        self.window = None
        for opt, short, desc in [
            ("toggle", "t", "Toggle popup"),
            ("show", "s", "Show popup"),
            ("hide", "h", "Hide popup"),
            ("clear", "c", "Clear all"),
            ("dnd", "D", "Toggle DND"),
            ("daemon", "d", "Run as daemon"),
            ("quit", "q", "Quit"),
        ]:
            self.add_main_option(
                opt, ord(short), GLib.OptionFlags.NONE, GLib.OptionArg.NONE, desc, None
            )

    def do_startup(self):
        Adw.Application.do_startup(self)
        Adw.StyleManager.get_default().set_color_scheme(Adw.ColorScheme.FORCE_DARK)
        install_css(extra_css=self.EXTRA_CSS)
        self.window = NothingNotifWindow(self)
        self.hold()

    def do_command_line(self, cmdline):
        opts = cmdline.get_options_dict().end().unpack()
        if "quit" in opts:
            self.quit()
            return 0
        if "clear" in opts:
            NotifSource.clear_all()
            return 0
        if "dnd" in opts:
            try:
                r = subprocess.run(
                    ["makoctl", "mode"], capture_output=True, text=True, timeout=1
                )
                if "do-not-disturb" in r.stdout:
                    subprocess.run(["makoctl", "mode", "-r", "do-not-disturb"])
                else:
                    subprocess.run(["makoctl", "mode", "-a", "do-not-disturb"])
            except Exception:
                pass
            return 0
        if "hide" in opts:
            self.window.hide_popup()
        elif "toggle" in opts:
            self.window.toggle_popup()
        elif "show" in opts:
            self.window.show_popup()
        elif "daemon" in opts:
            pass
        else:
            self.window.toggle_popup()
        return 0

    def do_activate(self):
        if self.window:
            self.window.toggle_popup()


if __name__ == "__main__":
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    app = NothingNotifApp()
    sys.exit(app.run(sys.argv))
