        color: rgba(255, 255, 255, 0.55);
        letter-spacing: 2.5px;
    }
    .section-header-clean {
        font-family: "Inter", sans-serif;
        font-weight: 600;
        font-size: 10px;
        color: rgba(255, 255, 255, 0.45);
        letter-spacing: 2.5px;
    }
    .tile-label {
        font-family: "Inter", sans-serif;
        font-weight: 600;
        font-size: 10px;
        color: rgba(255, 255, 255, 0.70);
        letter-spacing: 1.5px;
    }
