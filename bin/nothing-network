#!/usr/bin/env python3
"""
Nothing OS — Network
Unified with control/volume/notifications design language:
  - red glyph dot in header
  - hero dot-matrix wifi signal with concentric pulsing rings
  - CircleButton for Wi-Fi/Ethernet toggles
  - flat network rows with signal bars
  - password prompt as proper layer-shell window
"""

import os
import sys


def _ensure_layer_shell_preload():
    LAYER_SHELL_PATHS = [
        "/usr/lib/libgtk4-layer-shell.so",
        "/usr/lib/libgtk4-layer-shell.so.0",
        "/usr/lib64/libgtk4-layer-shell.so",
        "/usr/lib64/libgtk4-layer-shell.so.0",
        "/usr/lib/x86_64-linux-gnu/libgtk4-layer-shell.so",
        "/usr/lib/x86_64-linux-gnu/libgtk4-layer-shell.so.0",
    ]
    lib_path = next((p for p in LAYER_SHELL_PATHS if os.path.exists(p)), None)
    if not lib_path:
        return
    current = os.environ.get("LD_PRELOAD", "")
    if lib_path in current:
        return
    os.environ["LD_PRELOAD"] = f"{lib_path}:{current}" if current else lib_path
    os.execv(sys.executable, [sys.executable] + sys.argv)


_ensure_layer_shell_preload()

