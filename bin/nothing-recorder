class NothingRecorderWindow(Adw.ApplicationWindow):
    def __init__(self, app):
        super().__init__(application=app)
        self.app = app

        self.set_title("nothing-recorder")
        self.set_default_size(380, 540)
        self.set_resizable(False)
        self.add_css_class("popup-window")

        if HAS_LAYER_SHELL:
            LayerShell.init_for_window(self)
            LayerShell.set_namespace(self, "nothing-recorder")
            LayerShell.set_layer(self, LayerShell.Layer.OVERLAY)
            LayerShell.set_anchor(self, LayerShell.Edge.TOP, True)
            LayerShell.set_anchor(self, LayerShell.Edge.RIGHT, True)
            LayerShell.set_margin(self, LayerShell.Edge.TOP, 12)
            LayerShell.set_margin(self, LayerShell.Edge.RIGHT, 12)
            LayerShell.set_keyboard_mode(self, LayerShell.KeyboardMode.ON_DEMAND)
            LayerShell.set_exclusive_zone(self, 0)

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        outer.add_css_class("outer-wrap")

        scroll = Gtk.ScrolledWindow()
        scroll.add_css_class("card-scroller")
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.EXTERNAL)
        scroll.set_vexpand(True)
        scroll.set_overflow(Gtk.Overflow.HIDDEN)

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        card.add_css_class("main-card")

        # ─── Header ───
        header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        header.set_margin_top(22)
        header.set_margin_start(24)
        header.set_margin_end(24)
        header.set_margin_bottom(4)

        glyph_da = Gtk.DrawingArea()
        glyph_da.set_content_width(10)
        glyph_da.set_content_height(10)
        glyph_da.set_valign(Gtk.Align.CENTER)

        def _draw_glyph(a, cr, w, h):
            cr.set_source_rgb(*RED)
            cr.arc(w / 2, h / 2, 3, 0, 2 * math.pi)
            cr.fill()

        glyph_da.set_draw_func(_draw_glyph)
        header.append(glyph_da)

        title = Gtk.Label(label="RECORDER", xalign=0)
        title.add_css_class("window-title")
        title.set_hexpand(True)
        header.append(title)

        self.header_status = Gtk.Label(label="IDLE")
        self.header_status.add_css_class("header-meta")
        header.append(self.header_status)
        card.append(header)

        # ─── Hero ───
        hero = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        hero.set_halign(Gtk.Align.CENTER)
        hero.set_margin_top(14)
        hero.set_margin_bottom(8)
        self.hero = HeroREC(size=140)
        self.hero.set_halign(Gtk.Align.CENTER)
        hero.append(self.hero)

        self.hero_status = Gtk.Label(label="READY")
        self.hero_status.add_css_class("hero-date")
        hero.append(self.hero_status)

        self.elapsed_lbl = Gtk.Label(label="")
        self.elapsed_lbl.add_css_class("hero-time-mono")
        hero.append(self.elapsed_lbl)
        card.append(hero)

        # ─── Divider ───
        div = Gtk.DrawingArea()
        div.set_content_height(1)
        div.set_margin_top(18)
        div.set_margin_start(60)
        div.set_margin_end(60)

        def _draw_div(a, cr, w, h):
            cr.set_source_rgba(*WHITE_08)
            cr.rectangle(0, 0, w, h)
            cr.fill()

        div.set_draw_func(_draw_div)
        card.append(div)

        # ─── OPTIONS ───
        opt_hdr = self._mk_section_hdr("OPTIONS")
        card.append(opt_hdr)

        # Region toggle
        self.region_circle = CircleButton(_draw_region, size=40, toggle=True)
        self.region_adapter = AdapterRow("Region", _draw_region, self.region_circle)
        card.append(self.region_adapter)

        # Audio toggle
        self.audio_circle = CircleButton(_draw_mic, size=40, toggle=True)
        self.audio_adapter = AdapterRow(
            "Microphone audio", _draw_mic, self.audio_circle
        )
        card.append(self.audio_adapter)

        # ─── ACTION button ───
        act_wrap = Gtk.Box()
        act_wrap.set_margin_start(20)
        act_wrap.set_margin_end(20)
        act_wrap.set_margin_top(22)
        self.action_btn = Gtk.Button(label="START")
        self.action_btn.add_css_class("rec-btn-start")
        self.action_btn.set_hexpand(True)
        self.action_btn.connect("clicked", self._on_action)
        act_wrap.append(self.action_btn)
        card.append(act_wrap)

        # ─── LAST FILE ───
        last_hdr = self._mk_section_hdr("LAST FILE")
        card.append(last_hdr)

        self.last_file_row = Gtk.Button()
        self.last_file_row.add_css_class("last-file-row")
        self.last_file_row.set_margin_start(20)
        self.last_file_row.set_margin_end(20)
        self.last_file_row.connect("clicked", self._on_last_file_clicked)

        lf_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        lf_box.set_margin_top(10)
        lf_box.set_margin_bottom(10)
        lf_box.set_margin_start(14)
        lf_box.set_margin_end(14)

        file_icon = Gtk.DrawingArea()
        file_icon.set_content_width(18)
        file_icon.set_content_height(18)
        file_icon.set_valign(Gtk.Align.CENTER)
        file_icon.set_draw_func(
            lambda a, cr, w, h: _draw_file(cr, w / 2, h / 2, size=18, color=WHITE_50)
        )
        lf_box.append(file_icon)

        lf_info = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        lf_info.set_hexpand(True)
        lf_info.set_valign(Gtk.Align.CENTER)

        self.last_file_name = Gtk.Label(label="No recordings", xalign=0)
        self.last_file_name.add_css_class("last-file-name")
        self.last_file_name.set_ellipsize(Pango.EllipsizeMode.MIDDLE)
        lf_info.append(self.last_file_name)

        self.last_file_meta = Gtk.Label(label="", xalign=0)
        self.last_file_meta.add_css_class("last-file-meta")
        lf_info.append(self.last_file_meta)

        lf_box.append(lf_info)

        self.last_file_action = Gtk.Label(label="")
        self.last_file_action.add_css_class("row-action")
        self.last_file_action.set_valign(Gtk.Align.CENTER)
        lf_box.append(self.last_file_action)

        self.last_file_row.set_child(lf_box)
        card.append(self.last_file_row)

        bottom = Gtk.Box()
        bottom.set_size_request(-1, 28)
        card.append(bottom)

        scroll.set_child(card)
        outer.append(scroll)
        self.set_content(outer)

        wheel = Gtk.EventControllerScroll.new(Gtk.EventControllerScrollFlags.VERTICAL)
        wheel.connect("scroll", self._on_wheel, scroll)
        outer.add_controller(wheel)

        GLib.timeout_add(500, self._tick_state)
        self._tick_state()

        ctrl = Gtk.EventControllerKey()
        ctrl.connect("key-pressed", self._on_key)
        self.add_controller(ctrl)

    def _mk_section_hdr(self, name):
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        row.set_margin_start(28)
        row.set_margin_end(28)
        row.set_margin_top(22)
        row.set_margin_bottom(8)
        lbl = Gtk.Label(label=name, xalign=0)
        lbl.add_css_class("section-header-clean")
        lbl.set_hexpand(True)
        row.append(lbl)
        return row

    def _on_wheel(self, controller, dx, dy, scroller):
        adj = scroller.get_vadjustment()
        if adj is None:
            return False
        step = adj.get_step_increment() or 40
        new = adj.get_value() + dy * step
        new = max(adj.get_lower(), min(adj.get_upper() - adj.get_page_size(), new))
        adj.set_value(new)
        return True

    def _tick_state(self):
        rec = Recorder.is_recording()
        self.hero.set_recording(rec)

        if rec:
            self.hero_status.set_text("RECORDING")
            self.header_status.set_text("REC")
            self.action_btn.set_label("STOP")
            self.action_btn.remove_css_class("rec-btn-start")
            self.action_btn.add_css_class("rec-btn-stop")

            started = Recorder.started_at()
            if started:
                elapsed = int(time.time() - started)
                mm, ss = divmod(elapsed, 60)
                hh, mm = divmod(mm, 60)
                if hh:
                    self.elapsed_lbl.set_text(f"{hh:02d}:{mm:02d}:{ss:02d}")
                else:
                    self.elapsed_lbl.set_text(f"{mm:02d}:{ss:02d}")
            else:
                self.elapsed_lbl.set_text("")

            self.region_circle.set_sensitive(False)
            self.audio_circle.set_sensitive(False)
            self.region_adapter.set_icon_active(self.region_circle.get_active())
            self.audio_adapter.set_icon_active(self.audio_circle.get_active())
        else:
            self.hero_status.set_text("READY")
            self.header_status.set_text("IDLE")
            self.action_btn.set_label("START")
            self.action_btn.remove_css_class("rec-btn-stop")
            self.action_btn.add_css_class("rec-btn-start")
            self.elapsed_lbl.set_text("")
            self.region_circle.set_sensitive(True)
            self.audio_circle.set_sensitive(True)
            self.region_adapter.set_icon_active(self.region_circle.get_active())
            self.audio_adapter.set_icon_active(self.audio_circle.get_active())

        # Last file
        last = self._find_last_file()
        if last:
            path = Path(last)
            self.last_file_name.set_text(path.name)
            try:
                size_b = path.stat().st_size
                if size_b > 1024 * 1024:
                    size_str = f"{size_b / 1024 / 1024:.1f} MB"
                else:
                    size_str = f"{size_b / 1024:.0f} KB"
                self.last_file_meta.set_text(size_str)
            except Exception:
                self.last_file_meta.set_text("")
            self.last_file_action.set_text("OPEN")
            self.last_file_row.set_sensitive(True)
        else:
            self.last_file_name.set_text("No recordings yet")
            self.last_file_meta.set_text("")
            self.last_file_action.set_text("")
            self.last_file_row.set_sensitive(False)

        return True

    def _find_last_file(self):
        if Recorder.is_recording():
            out = Recorder.output_path()
            if out and os.path.exists(out):
                return out
        if not OUTPUT_DIR.exists():
            return None
        try:
            files = sorted(
                OUTPUT_DIR.glob("rec_*.mp4"),
                key=lambda p: p.stat().st_mtime,
                reverse=True,
            )
            if files:
                return str(files[0])
        except Exception:
            pass
        return None

    def _on_last_file_clicked(self, _btn):
        last = self._find_last_file()
        if last:
            subprocess.Popen(
                ["xdg-open", last],
                start_new_session=True,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )

    def _on_action(self, _btn):
        if Recorder.is_recording():
            out_path = Recorder.output_path()
            Recorder.stop()
            threading.Thread(
                target=send_recording_stopped_notification,
                args=(out_path,),
                daemon=True,
            ).start()
        else:
            region = self.region_circle.get_active()
            audio = self.audio_circle.get_active()
            if region:
                # Hide popup briefly so slurp can paint the screen
                self.set_visible(False)
                GLib.timeout_add(
                    200, lambda: (self._start_with_notify(region, audio), False)[1]
                )
            else:
                self._start_with_notify(region, audio)
        GLib.timeout_add(300, lambda: (self._tick_state(), False)[1])

    def _start_with_notify(self, region, audio):
        ok, err = Recorder.start(region=region, audio=audio)
        if ok:
            send_recording_started_notification(region, audio)
        else:
            notify_error(
                "Recording failed",
                err or "Could not start wf-recorder",
                app="nothing-recorder",
            )
        return False

    def _on_key(self, c, keyval, *a):
        if keyval == Gdk.KEY_Escape:
            self.hide_popup()
            return True
        return False

    def show_popup(self):
        close_other_popups("nothing-recorder")
        self._tick_state()
        self.set_visible(True)
        self.present()
        self.set_opacity(0.0)
        fade_in(self, duration_ms=180)

    def hide_popup(self):
        fade_out(self, duration_ms=140, on_done=lambda: self.set_visible(False))

    def toggle_popup(self):
        if self.get_visible():
            self.hide_popup()
        else:
            self.show_popup()


