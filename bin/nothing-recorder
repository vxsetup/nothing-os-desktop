        transition: all 120ms ease;
    }
    .rec-btn-start:hover {
        background-color: rgba(255, 45, 45, 0.10);
        border-color: rgba(255, 45, 45, 0.55);
        color: #FF2D2D;
    }

    /* Big action button — STOP (red filled) */
    .rec-btn-stop {
        font-family: "JetBrains Mono", monospace;
        font-weight: 700;
        font-size: 12px;
        letter-spacing: 4px;
        padding: 16px 0;
        border-radius: 28px;
        background-color: #FF2D2D;
        border: 1px solid #FF2D2D;
        color: #FFFFFF;
        min-height: 0;
        transition: all 120ms ease;
    }
    .rec-btn-stop:hover {
        background-color: #FF4747;
        border-color: #FF4747;
    }

    /* Last file row — flat clickable */
    .last-file-row {
        background: transparent;
        background-color: transparent;
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 0;
        min-height: 0;
        box-shadow: none;
        transition: background-color 120ms ease,
                    border-color 120ms ease;
    }
    .last-file-row:hover {
        background-color: rgba(255, 255, 255, 0.04);
        border-color: rgba(255, 255, 255, 0.12);
    }
    .last-file-row:hover .row-action {
        color: #FF2D2D;
    }
    .last-file-row:disabled {
        opacity: 0.5;
    }
    .last-file-name {
        font-family: "Inter", sans-serif;
        font-weight: 600;
        font-size: 12px;
        color: #FFFFFF;
        letter-spacing: 0.1px;
    }
    .last-file-meta {
        font-family: "JetBrains Mono", monospace;
        font-weight: 500;
        font-size: 9px;
        color: rgba(255, 255, 255, 0.40);
        letter-spacing: 1px;
    }
    """

    def __init__(self):
        super().__init__(
            application_id="tech.nothing.recorder",
            flags=Gio.ApplicationFlags.HANDLES_COMMAND_LINE,
        )
        self.window = None
        for opt, short, desc in [
            ("toggle", "t", "Toggle popup"),
            ("show", "s", "Show popup"),
            ("hide", "h", "Hide popup"),
            ("toggle-rec", "r", "Toggle recording (no UI)"),
            ("start", "S", "Start recording"),
            ("start-region", "R", "Start recording region"),
            ("stop", "X", "Stop recording"),
            ("daemon", "d", "Daemon mode"),
            ("quit", "q", "Quit"),
        ]:
            self.add_main_option(
                opt, ord(short), GLib.OptionFlags.NONE, GLib.OptionArg.NONE, desc, None
            )

    def do_startup(self):
        Adw.Application.do_startup(self)
        Adw.StyleManager.get_default().set_color_scheme(Adw.ColorScheme.FORCE_DARK)
        install_css(extra_css=self.EXTRA_CSS)
        self.window = NothingRecorderWindow(self)
        self.hold()

    def do_command_line(self, cmdline):
        opts = cmdline.get_options_dict().end().unpack()
        w = self.window

        if "quit" in opts:
            self.quit()
            return 0

        def cli_start(region=False, audio=False):
            def worker():
                ok, err = Recorder.start(region=region, audio=audio)
                if ok:
                    send_recording_started_notification(region, audio)
                else:
                    notify_error(
                        "Recording failed",
                        err or "Unknown error",
                        app="nothing-recorder",
                    )

            threading.Thread(target=worker, daemon=True).start()

        def cli_stop():
            def worker():
                out_path = Recorder.output_path()
                Recorder.stop()
                send_recording_stopped_notification(out_path)

            threading.Thread(target=worker, daemon=True).start()

        if "start" in opts:
            cli_start()
            return 0
        if "start-region" in opts:
            cli_start(region=True)
            return 0
        if "stop" in opts:
            cli_stop()
            return 0
        if "toggle-rec" in opts:
            if Recorder.is_recording():
                cli_stop()
            else:
                cli_start()
            return 0
        if "hide" in opts:
            w.hide_popup()
        elif "show" in opts:
            w.show_popup()
        elif "toggle" in opts:
            w.toggle_popup()
        elif "daemon" in opts:
            pass
        else:
            w.toggle_popup()
        return 0

    def do_activate(self):
        if self.window:
            self.window.toggle_popup()


if __name__ == "__main__":
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    app = NothingRecorderApp()
    sys.exit(app.run(sys.argv))
