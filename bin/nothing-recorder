STATE_FILE = Path("/tmp/nothing-recorder.state")
PID_FILE = Path("/tmp/nothing-recorder.pid")
LOG_FILE = Path("/tmp/nothing-recorder.log")
OUTPUT_DIR = Path.home() / "Videos" / "NothingRec"

# ═════════════════════════════════════════════════════════════
#  Palette
# ═════════════════════════════════════════════════════════════

RED = (1.000, 0.176, 0.176)
WHITE = (1.0, 1.0, 1.0, 1.0)
WHITE_95 = (1.0, 1.0, 1.0, 0.95)
WHITE_85 = (1.0, 1.0, 1.0, 0.85)
WHITE_70 = (1.0, 1.0, 1.0, 0.70)
WHITE_50 = (1.0, 1.0, 1.0, 0.50)
WHITE_25 = (1.0, 1.0, 1.0, 0.25)
WHITE_12 = (1.0, 1.0, 1.0, 0.12)
WHITE_08 = (1.0, 1.0, 1.0, 0.08)
WHITE_06 = (1.0, 1.0, 1.0, 0.06)


def log(msg):
    print(f"[rec] {msg}", file=sys.stderr, flush=True)


# ═════════════════════════════════════════════════════════════
#  Compositor detection helpers
# ═════════════════════════════════════════════════════════════


def _hyprland_focused_monitor():
    """Get the focused monitor name via Hyprland IPC."""
    try:
        r = subprocess.run(
            ["hyprctl", "monitors", "-j"], capture_output=True, text=True, timeout=2
        )
        if r.returncode == 0 and r.stdout:
            mons = json.loads(r.stdout)
            for m in mons:
                if m.get("focused"):
                    return m.get("name")
            if mons:
                return mons[0].get("name")
    except Exception as e:
        log(f"hyprctl monitors: {e}")
    return None


def _wlr_first_output():
    """Fallback: try to get first output from wlr-randr."""
    if not shutil.which("wlr-randr"):
        return None
    try:
        r = subprocess.run(["wlr-randr"], capture_output=True, text=True, timeout=2)
        if r.returncode == 0 and r.stdout:
            for line in r.stdout.split("\n"):
                if line and not line.startswith(" "):
                    # First non-indented line is monitor name
                    name = line.split()[0]
                    if name:
                        return name
    except Exception:
        pass
    return None


def _detect_output():
    """Detect screen output to record from."""
    # Try Hyprland first
    out = _hyprland_focused_monitor()
    if out:
        return out
    # Try wlr-randr
    out = _wlr_first_output()
    if out:
        return out
    return None


def _detect_audio_source():
    """Return default pipewire/pulse source for --audio=NAME."""
    try:
        r = subprocess.run(
            ["pactl", "get-default-sink"], capture_output=True, text=True, timeout=2
        )
        if r.returncode == 0 and r.stdout.strip():
            # wf-recorder captures monitor of sink: <sink>.monitor
            return r.stdout.strip() + ".monitor"
    except Exception:
        pass
    return None


# ═════════════════════════════════════════════════════════════
#  Recorder backend (with bug fix)
# ═════════════════════════════════════════════════════════════


class Recorder:
    @staticmethod
    def is_recording():
        if not PID_FILE.exists():
            return False
        try:
            pid = int(PID_FILE.read_text().strip())
            os.kill(pid, 0)
            return True
        except Exception:
            try:
                PID_FILE.unlink(missing_ok=True)
                STATE_FILE.unlink(missing_ok=True)
            except Exception:
                pass
            return False

    @staticmethod
    def started_at():
        if STATE_FILE.exists():
            try:
                for line in STATE_FILE.read_text().strip().split("\n"):
                    if line.startswith("start="):
                        return float(line.split("=", 1)[1])
            except Exception:
                pass
        return None

    @staticmethod
    def output_path():
        if STATE_FILE.exists():
            try:
                for line in STATE_FILE.read_text().strip().split("\n"):
                    if line.startswith("file="):
                        return line.split("=", 1)[1]
            except Exception:
                pass
        return None

    @staticmethod
    def start(region=False, audio=False):
        """Returns (success, error_message)."""
        if Recorder.is_recording():
            return (False, "Already recording")

        if not shutil.which("wf-recorder"):
            return (False, "wf-recorder not installed")

        OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
        ts = time.strftime("%Y-%m-%d_%H-%M-%S")
        out = OUTPUT_DIR / f"rec_{ts}.mp4"

        cmd = ["wf-recorder"]

        # ─── Geometry / output selection ───
        if region:
            if not shutil.which("slurp"):
                return (False, "slurp not installed (needed for region)")
            try:
                r = subprocess.run(
                    ["slurp"], capture_output=True, text=True, timeout=60
                )
                geom = r.stdout.strip()
                if not geom:
                    return (False, "Region selection cancelled")
                cmd += ["-g", geom]
            except subprocess.TimeoutExpired:
                return (False, "Region selection timed out")
            except Exception as e:
                return (False, f"slurp error: {e}")
        else:
            # ★ BUG FIX: explicitly select output for full-screen
            # Without this wf-recorder may fail silently on multi-monitor
            output = _detect_output()
            if output:
                cmd += ["-o", output]
                log(f"recording output: {output}")
            else:
                log("warning: no output detected, wf-recorder will use default")

        # ─── Audio ───
        if audio:
            src = _detect_audio_source()
            if src:
                cmd += [f"--audio={src}"]
                log(f"audio source: {src}")
            else:
                cmd += ["--audio"]  # let wf-recorder pick default

        # ─── Codec (h264 hardware accel where possible) ───
        # Soft fallback to libx264 if vaapi not available
        cmd += [
            "-c",
            "libx264",
            "-p",
            "preset=ultrafast",
            "-p",
            "crf=23",
            "-p",
            "pix_fmt=yuv420p",
        ]

        # ─── Output file ───
        cmd += ["-f", str(out)]

        log(f"command: {' '.join(cmd)}")

        # Run and capture initial stderr to detect immediate failure
        try:
            log_fh = open(LOG_FILE, "w")
            proc = subprocess.Popen(
                cmd, stdout=log_fh, stderr=subprocess.STDOUT, start_new_session=True
            )
        except Exception as e:
            return (False, f"Failed to spawn: {e}")

        # Check it actually started (give it 0.6s to crash)
        time.sleep(0.6)
        if proc.poll() is not None:
            # Process died immediately, read log
            try:
                log_text = LOG_FILE.read_text().strip()
            except Exception:
                log_text = ""
            log(f"wf-recorder died: {log_text}")
            return (
                False,
                log_text[:200] if log_text else "wf-recorder exited immediately",
            )

        # Success — write state
        PID_FILE.write_text(str(proc.pid))
        STATE_FILE.write_text(
            f"start={time.time()}\n"
            f"file={out}\n"
            f"audio={int(audio)}\n"
            f"region={int(region)}\n"
        )
        return (True, "")

    @staticmethod
    def stop():
        if not Recorder.is_recording():
            return False
        try:
            pid = int(PID_FILE.read_text().strip())
            # Send SIGINT to process group (start_new_session creates group)
            try:
                os.killpg(os.getpgid(pid), signal.SIGINT)
            except ProcessLookupError:
                pass
            except Exception:
                # Fallback: just signal main pid
                try:
                    os.kill(pid, signal.SIGINT)
                except Exception:
                    pass

            # Wait up to 3 seconds for graceful shutdown (file flush)
            for _ in range(60):
                try:
                    os.kill(pid, 0)
                    time.sleep(0.05)
                except Exception:
                    break
            else:
                # Force kill if still alive
                try:
                    os.killpg(os.getpgid(pid), signal.SIGKILL)
                except Exception:
                    pass
        except Exception as e:
            log(f"stop: {e}")
        try:
            PID_FILE.unlink(missing_ok=True)
            STATE_FILE.unlink(missing_ok=True)
        except Exception:
            pass
        return True


def send_recording_started_notification(region, audio):
    body = []
    body.append("Region" if region else "Full screen")
    if audio:
        body.append("Audio on")
    notify(
        "Recording started",
        " · ".join(body),
        app="nothing-recorder",
        icon="media-record",
        urgency="normal",
        timeout=2500,
    )


def send_recording_stopped_notification(path):
    if not path or not os.path.exists(path):
        notify_info("Recording stopped", app="nothing-recorder", timeout=2000)
        return
    nid = notify(
        "Recording saved",
        os.path.basename(path),
        app="nothing-recorder",
        icon="media-record",
        urgency="normal",
        timeout=5000,
        actions=[("open", "Open"), ("folder", "Folder"), ("delete", "Delete")],
    )

    def on_action(action_id):
        if action_id == "open":
            subprocess.Popen(
                ["xdg-open", path],
                start_new_session=True,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
        elif action_id == "folder":
            subprocess.Popen(
                ["xdg-open", os.path.dirname(path)],
                start_new_session=True,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
        elif action_id == "delete":
            try:
                os.remove(path)
                notify_success("Recording deleted", app="nothing-recorder")
            except Exception as e:
                notify_error("Delete failed", str(e), app="nothing-recorder")

    listen_for_action(nid, on_action, timeout=15)


# ═════════════════════════════════════════════════════════════
#  Shape helpers
# ═════════════════════════════════════════════════════════════


def round_rect(cr, x, y, w, h, r):
    cr.new_sub_path()
    cr.arc(x + w - r, y + r, r, -math.pi / 2, 0)
    cr.arc(x + w - r, y + h - r, r, 0, math.pi / 2)
    cr.arc(x + r, y + h - r, r, math.pi / 2, math.pi)
    cr.arc(x + r, y + r, r, math.pi, 3 * math.pi / 2)
    cr.close_path()


def _resolve_color(color, fallback):
    if color is None:
        c = fallback
    else:
        c = color
    if len(c) == 3:
        return (*c, 1.0)
    return c


# ═════════════════════════════════════════════════════════════
#  Cairo glyphs
# ═════════════════════════════════════════════════════════════


def _draw_region(cr, cx, cy, active=False, size=22, color=None):
    """Crop / region selection icon — 4 corner brackets."""
    col = _resolve_color(color, WHITE_85)
    cr.set_source_rgba(*col)
    cr.set_line_width(2.0)
    cr.set_line_cap(cairo.LINE_CAP_ROUND)
    s = size * 0.36
    L = size * 0.16
    # Top-left
    cr.move_to(cx - s, cy - s + L)
    cr.line_to(cx - s, cy - s)
    cr.line_to(cx - s + L, cy - s)
    cr.stroke()
    # Top-right
    cr.move_to(cx + s - L, cy - s)
    cr.line_to(cx + s, cy - s)
    cr.line_to(cx + s, cy - s + L)
    cr.stroke()
    # Bottom-left
    cr.move_to(cx - s, cy + s - L)
    cr.line_to(cx - s, cy + s)
    cr.line_to(cx - s + L, cy + s)
    cr.stroke()
    # Bottom-right
    cr.move_to(cx + s - L, cy + s)
    cr.line_to(cx + s, cy + s)
    cr.line_to(cx + s, cy + s - L)
    cr.stroke()


def _draw_mic(cr, cx, cy, active=False, size=22, color=None):
    col = _resolve_color(color, WHITE_85)
    cr.set_source_rgba(*col)
    cr.set_line_width(2.0)
    cr.set_line_cap(cairo.LINE_CAP_ROUND)
    cr.set_line_join(cairo.LINE_JOIN_ROUND)
    s = size * 0.30
    round_rect(cr, cx - s * 0.55, cy - s * 1.05, s * 1.10, s * 1.30, s * 0.55)
    cr.fill()
    cr.arc(cx, cy + s * 0.10, s * 0.85, 0.25, math.pi - 0.25)
    cr.stroke()
    cr.move_to(cx, cy + s * 0.95)
    cr.line_to(cx, cy + s * 1.30)
    cr.stroke()
    cr.move_to(cx - s * 0.50, cy + s * 1.30)
    cr.line_to(cx + s * 0.50, cy + s * 1.30)
    cr.stroke()


def _draw_file(cr, cx, cy, active=False, size=22, color=None):
    col = _resolve_color(color, WHITE_85)
    cr.set_source_rgba(*col)
    cr.set_line_width(2.0)
    cr.set_line_cap(cairo.LINE_CAP_ROUND)
    cr.set_line_join(cairo.LINE_JOIN_ROUND)
    s = size * 0.32
    # Document outline with folded corner
    cr.move_to(cx - s * 0.85, cy - s)
    cr.line_to(cx + s * 0.40, cy - s)
    cr.line_to(cx + s * 0.85, cy - s * 0.55)
    cr.line_to(cx + s * 0.85, cy + s)
    cr.line_to(cx - s * 0.85, cy + s)
    cr.close_path()
    cr.stroke()
    # Folded corner
    cr.move_to(cx + s * 0.40, cy - s)
    cr.line_to(cx + s * 0.40, cy - s * 0.55)
    cr.line_to(cx + s * 0.85, cy - s * 0.55)
    cr.stroke()


# ═════════════════════════════════════════════════════════════
#  CircleButton (shared)
# ═════════════════════════════════════════════════════════════


class CircleButton(Gtk.DrawingArea):
    __gsignals__ = {
        "clicked": (GObject.SignalFlags.RUN_LAST, None, ()),
        "toggled": (GObject.SignalFlags.RUN_LAST, None, (bool,)),
    }

    def __init__(self, icon_fn, size=40, active=False, toggle=False, accent_only=False):
        super().__init__()
        self.icon_fn = icon_fn
        self._size = size
        self._active = active
        self._toggle = toggle
        self._accent_only = accent_only
        self._busy = False
        self._busy_start = 0
        self._hover = False
        self._press = False

        self.set_content_width(size)
        self.set_content_height(size)
        self.set_halign(Gtk.Align.CENTER)
        self.set_valign(Gtk.Align.CENTER)
        self.set_draw_func(self._draw)

        click = Gtk.GestureClick()
        click.set_button(1)
        click.connect("pressed", self._on_press)
        click.connect("released", self._on_release)
        self.add_controller(click)

        hover = Gtk.EventControllerMotion()
        hover.connect("enter", self._on_enter)
        hover.connect("leave", self._on_leave)
        self.add_controller(hover)

    def _on_enter(self, *a):
        self._hover = True
        self.queue_draw()

    def _on_leave(self, *a):
        self._hover = False
        self._press = False
        self.queue_draw()

    def _on_press(self, *a):
        self._press = True
        self.queue_draw()

    def _on_release(self, *a):
        was_press = self._press
        self._press = False
        if was_press and not self._busy:
            if self._toggle:
                self._busy = True
                self._busy_start = time.monotonic()
                self._active = not self._active
                self.emit("toggled", self._active)
                GLib.timeout_add(16, self._tick)
            else:
                self.emit("clicked")
        self.queue_draw()

    def _tick(self):
        elapsed = (time.monotonic() - self._busy_start) * 1000
        if elapsed >= 350:
            self._busy = False
            self.queue_draw()
            return False
        self.queue_draw()
        return True

    def set_active(self, a, emit=False):
        if a != self._active:
            self._active = a
            self.queue_draw()
            if emit:
                self.emit("toggled", self._active)

    def get_active(self):
        return self._active

    def _draw(self, area, cr, w, h):
        cx = w / 2
        cy = h / 2
        r = min(w, h) / 2 - 1

        is_red = self._active or self._accent_only
        if is_red:
            if self._press:
                cr.set_source_rgba(0.80 * RED[0], 0.80 * RED[1], 0.80 * RED[2], 1.0)
            else:
                cr.set_source_rgb(*RED)
            cr.arc(cx, cy, r, 0, 2 * math.pi)
            cr.fill()
        else:
            if self._press:
                cr.set_source_rgba(*WHITE_12)
            elif self._hover:
                cr.set_source_rgba(*WHITE_08)
            else:
                cr.set_source_rgba(*WHITE_06)
            cr.arc(cx, cy, r, 0, 2 * math.pi)
            cr.fill()
            cr.set_source_rgba(*WHITE_08)
            cr.set_line_width(1)
            cr.arc(cx, cy, r - 0.5, 0, 2 * math.pi)
            cr.stroke()

        icon_size = int(self._size * 0.50)
        if is_red:
            self.icon_fn(cr, cx, cy, False, icon_size, color=WHITE)
        else:
            self.icon_fn(cr, cx, cy, False, icon_size, color=(1.0, 1.0, 1.0, 0.92))

        if self._busy:
            elapsed = (time.monotonic() - self._busy_start) * 1000
            progress = min(1.0, elapsed / 350)
            cr.set_line_width(1.5)
            cr.set_line_cap(cairo.LINE_CAP_ROUND)
            if is_red:
                cr.set_source_rgba(1, 1, 1, 0.80)
            else:
                cr.set_source_rgba(RED[0], RED[1], RED[2], 0.85)
            start_a = -math.pi / 2
            end_a = start_a + (2 * math.pi * progress)
            cr.arc(cx, cy, r + 2, start_a, end_a)
            cr.stroke()


# ═════════════════════════════════════════════════════════════
#  AdapterRow (shared pattern)
# ═════════════════════════════════════════════════════════════


class AdapterRow(Gtk.Box):
    def __init__(self, label, icon_fn, right_widget):
        super().__init__(orientation=Gtk.Orientation.HORIZONTAL, spacing=14)
        self.set_margin_start(28)
        self.set_margin_end(20)
        self.set_margin_top(8)
        self.set_margin_bottom(8)

        self.icon_area = Gtk.DrawingArea()
        self.icon_area.set_content_width(20)
        self.icon_area.set_content_height(20)
        self.icon_area.set_valign(Gtk.Align.CENTER)
        self._icon_fn = icon_fn
        self._icon_active = False
        self.icon_area.set_draw_func(self._draw_icon)
        self.append(self.icon_area)

        lbl = Gtk.Label(label=label, xalign=0)
        lbl.add_css_class("adapter-label-clean")
        lbl.set_hexpand(True)
        self.append(lbl)

        right_widget.set_valign(Gtk.Align.CENTER)
        self.append(right_widget)

    def _draw_icon(self, area, cr, w, h):
        col = (*RED, 1.0) if self._icon_active else WHITE_70
        self._icon_fn(cr, w / 2, h / 2, False, 20, color=col)

    def set_icon_active(self, active):
        if active != self._icon_active:
            self._icon_active = active
            self.icon_area.queue_draw()


# ═════════════════════════════════════════════════════════════
#  StatusDot
# ═════════════════════════════════════════════════════════════


class StatusDot(Gtk.DrawingArea):
    def __init__(self, size=10):
        super().__init__()
        self.active = False
        self.set_content_width(size)
        self.set_content_height(size)
        self.set_draw_func(self._draw)

    def set_active(self, a):
        self.active = a
        self.queue_draw()

    def _draw(self, area, cr, w, h):
        cx, cy = w / 2, h / 2
        r = min(w, h) / 2 - 1
        if self.active:
            cr.set_source_rgb(*RED)
            cr.arc(cx, cy, r, 0, 2 * math.pi)
            cr.fill()
        else:
            cr.set_source_rgba(*WHITE_25)
            cr.set_line_width(1.0)
            cr.arc(cx, cy, r - 0.5, 0, 2 * math.pi)
            cr.stroke()


# ═════════════════════════════════════════════════════════════
#  Hero REC — dot-matrix
# ═════════════════════════════════════════════════════════════


class HeroREC(Gtk.DrawingArea):
    """Big REC dot-matrix indicator. Pulses red when recording."""

    LETTERS = {
        "R": ["11110", "10001", "10001", "11110", "10100", "10010", "10001"],
        "E": ["11111", "10000", "10000", "11110", "10000", "10000", "11111"],
        "C": ["01111", "10000", "10000", "10000", "10000", "10000", "01111"],
        " ": ["00000", "00000", "00000", "00000", "00000", "00000", "00000"],
    }

    DOT = [
        "00000",
        "00000",
        "01110",
        "11111",
        "11111",
        "01110",
        "00000",
    ]

    def __init__(self, size=140):
        super().__init__()
        self.recording = False
        self._phase = 0.0
        self.size = size
        self.set_content_width(size)
        self.set_content_height(size)
        self.set_draw_func(self._draw)
        GLib.timeout_add(60, self._tick)

    def set_recording(self, on):
        if on != self.recording:
            self.recording = on
            self.queue_draw()

    def _tick(self):
        if self.recording:
            self._phase = (self._phase + 0.04) % 1.0
            self.queue_draw()
        return True

    def _draw(self, area, cr, w, h):
        rows = 7
        cell = min(h / (rows + 2.5), 10)
        char_w = 5 * cell
        gap = cell * 0.7
        dot_r = cell * 0.42
        dot_r_off = cell * 0.16

        if self.recording:
            # 'REC' + leading dot
            chars = ["●", "R", "E", "C"]
        else:
            chars = ["R", "E", "C"]

        total_w = len(chars) * char_w + (len(chars) - 1) * gap
        start_x = (w - total_w) / 2
        start_y = (h - rows * cell) / 2

        for ci, ch in enumerate(chars):
            if ch == "●":
                glyph = self.DOT
            else:
                glyph = self.LETTERS.get(ch, self.LETTERS[" "])
            gx = start_x + ci * (char_w + gap)
            for r in range(rows):
                for c in range(5):
                    x = gx + c * cell + cell / 2
                    y = start_y + r * cell + cell / 2
                    on = glyph[r][c] == "1"
                    if on:
                        if self.recording:
                            if ch == "●":
                                # Pulse the red dot
                                br = 0.55 + 0.45 * abs(
                                    math.sin(self._phase * 2 * math.pi)
                                )
                                cr.set_source_rgba(RED[0], RED[1], RED[2], br)
                            else:
                                cr.set_source_rgb(*RED)
                        else:
                            cr.set_source_rgba(*WHITE_50)
                        cr.arc(x, y, dot_r, 0, 2 * math.pi)
                    else:
                        cr.set_source_rgba(*WHITE_06)
                        cr.arc(x, y, dot_r_off, 0, 2 * math.pi)
                    cr.fill()


