            ("show", "s", "Show popup"),
            ("hide", "h", "Hide popup"),
            ("full", "F", "Quick full screen shot"),
            ("region", "R", "Quick region shot"),
            ("window", "W", "Quick window shot"),
            ("daemon", "d", "Daemon"),
            ("quit", "q", "Quit"),
        ]:
            self.add_main_option(
                opt, ord(short), GLib.OptionFlags.NONE, GLib.OptionArg.NONE, desc, None
            )

    def do_startup(self):
        Gtk.Application.do_startup(self)
        # Install shared CSS first
        install_css(extra_css=self.EXTRA_CSS)
        self.window = NothingScreenshotWindow(self)
        self.hold()

    def do_command_line(self, cmdline):
        opts = cmdline.get_options_dict().end().unpack()
        if "quit" in opts:
            self.quit()
            return 0

        def quick_shot(mode):
            def worker():
                log(f"CLI quick_shot: mode={mode}")
                if mode == "full":
                    path = Shooter.shoot_full(save=True, copy=True)
                elif mode == "region":
                    path = Shooter.shoot_region(save=True, copy=True)
                else:
                    path = Shooter.shoot_window(save=True, copy=True)
                log(f"CLI shot result: {path!r}")
                send_screenshot_notification(path, copied=True)

            threading.Thread(target=worker, daemon=True).start()

        if "full" in opts:
            quick_shot("full")
            return 0
        if "region" in opts:
            quick_shot("region")
            return 0
        if "window" in opts:
            quick_shot("window")
            return 0
        if "hide" in opts:
            self.window.hide_popup()
        elif "show" in opts:
            self.window.show_popup()
        elif "toggle" in opts:
            self.window.toggle_popup()
        elif "daemon" in opts:
            pass
        else:
            self.window.toggle_popup()
        return 0

    def do_activate(self):
        if self.window:
            self.window.toggle_popup()


if __name__ == "__main__":
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    log("=== nothing-screenshot started ===")
    app = NothingScreenshotApp()
    sys.exit(app.run(sys.argv))
