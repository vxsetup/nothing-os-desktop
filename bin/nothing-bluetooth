        letter-spacing: 1.5px;
    }
    .list-row:hover .row-action {
        color: #FFFFFF;
    }
    .list-row.active .row-action {
        color: #FF2D2D;
    }
    """

    def __init__(self):
        super().__init__(
            application_id="tech.nothing.bluetooth",
            flags=Gio.ApplicationFlags.HANDLES_COMMAND_LINE,
        )
        self.window = None
        for opt, short, desc in [
            ("toggle", "t", "Toggle popup"),
            ("show", "s", "Show popup"),
            ("hide", "h", "Hide popup"),
            ("daemon", "d", "Run as daemon"),
            ("quit", "q", "Quit"),
        ]:
            self.add_main_option(
                opt, ord(short), GLib.OptionFlags.NONE, GLib.OptionArg.NONE, desc, None
            )

    def do_startup(self):
        Adw.Application.do_startup(self)
        Adw.StyleManager.get_default().set_color_scheme(Adw.ColorScheme.FORCE_DARK)
        install_css(extra_css=self.EXTRA_CSS)
        self.window = NothingBluetoothWindow(self)
        self.hold()

    def do_command_line(self, command_line):
        options = command_line.get_options_dict().end().unpack()
        if "quit" in options:
            self.quit()
            return 0
        if "hide" in options:
            self.window.hide_popup()
        elif "toggle" in options:
            self.window.toggle_popup()
        elif "show" in options:
            self.window.show_popup()
        elif "daemon" in options:
            pass
        else:
            self.window.toggle_popup()
        return 0

    def do_activate(self):
        if self.window:
            self.window.toggle_popup()


if __name__ == "__main__":
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    app = NothingBluetoothApp()
    sys.exit(app.run(sys.argv))
