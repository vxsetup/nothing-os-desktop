        hint_lbl.set_margin_bottom(4)
        card.append(hint_lbl)

        # ─── Agenda section ───
        ag_hdr_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        ag_hdr_row.set_margin_start(28)
        ag_hdr_row.set_margin_end(28)
        ag_hdr_row.set_margin_top(20)
        ag_hdr_row.set_margin_bottom(8)
        self.ag_lbl = Gtk.Label(label="AGENDA", xalign=0)
        self.ag_lbl.add_css_class("section-header-clean")
        self.ag_lbl.set_hexpand(True)
        ag_hdr_row.append(self.ag_lbl)
        self.ag_counter = Gtk.Label(label="")
        self.ag_counter.add_css_class("section-counter-mono")
        ag_hdr_row.append(self.ag_counter)
        card.append(ag_hdr_row)

        self.events_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.events_box.set_margin_start(20)
        self.events_box.set_margin_end(20)
        card.append(self.events_box)

        self.empty_lbl = Gtk.Label(label="NO EVENTS")
        self.empty_lbl.add_css_class("empty-label-clean")
        self.empty_lbl.set_margin_top(28)
        self.empty_lbl.set_margin_bottom(28)
        card.append(self.empty_lbl)

        bottom = Gtk.Box()
        bottom.set_size_request(-1, 28)
        card.append(bottom)

        scroll.set_child(card)
        outer.append(scroll)
        self.set_content(outer)

        wheel = Gtk.EventControllerScroll.new(Gtk.EventControllerScrollFlags.VERTICAL)
        wheel.connect("scroll", self._on_wheel, scroll)
        outer.add_controller(wheel)

        ctrl = Gtk.EventControllerKey()
        ctrl.connect("key-pressed", self._on_key)
        self.add_controller(ctrl)

        self._kick_refresh()
        GLib.timeout_add(30000, self._auto_refresh)
        self._update_view()

    def _on_wheel(self, controller, dx, dy, scroller):
        adj = scroller.get_vadjustment()
        if adj is None:
            return False
        step = adj.get_step_increment() or 40
        new = adj.get_value() + dy * step
        new = max(adj.get_lower(), min(adj.get_upper() - adj.get_page_size(), new))
        adj.set_value(new)
        return True

    def _shift_month(self, delta):
        m = self._view_month + delta
        y = self._view_year
        while m < 1:
            m += 12
            y -= 1
        while m > 12:
            m -= 12
            y += 1
        self._view_year = y
        self._view_month = m
        self._update_view()

    def _on_today(self, *a):
        today = datetime.date.today()
        self._view_year = today.year
        self._view_month = today.month
        self._selected = today
        self._update_view()

    def _on_day_clicked(self, _g, y, m, d):
        try:
            self._selected = datetime.date(y, m, d)
            self._update_view()
        except Exception:
            pass

    def _on_day_long_clicked(self, _g, y, m, d):
        try:
            target = datetime.date(y, m, d)
        except Exception:
            return
        self._open_editor(default_date=target)

    def _kick_refresh(self):
        if self._refresh_pending:
            return
        self._refresh_pending = True

        def worker():
            try:
                events = EventsSource.load()
            except Exception as e:
                print(f"[cal] events: {e}", file=sys.stderr)
                events = []
            GLib.idle_add(self._apply, events)

        threading.Thread(target=worker, daemon=True).start()

    def _apply(self, events):
        self._refresh_pending = False
        self._events = events
        self._update_view()
        return False

    def _auto_refresh(self):
        if self.get_visible():
            self._kick_refresh()
        return True

    def _update_view(self):
        today = datetime.date.today()
        is_today_sel = self._selected == today

        self.hero_day.set_text(f"{self._selected.day:02d}", is_today=is_today_sel)
        self.hero_meta.set_text(self._selected.strftime("%A · %B %Y").upper())
        self.month_lbl.set_text(
            datetime.date(self._view_year, self._view_month, 1)
            .strftime("%B %Y")
            .upper()
        )

        self.grid.set_month(self._view_year, self._view_month)
        self.grid.set_selected(self._selected)
        self.grid.set_events_dates([e["date"] for e in self._events])

        day_events = EventsSource.for_date(self._events, self._selected)
        if is_today_sel and day_events:
            self.ag_lbl.set_text("TODAY")
        elif day_events:
            self.ag_lbl.set_text("SELECTED DAY")
        else:
            self.ag_lbl.set_text("UPCOMING")

        display = (
            day_events if day_events else EventsSource.upcoming(self._events, days=30)
        )

        self.ag_counter.set_text(str(len(display)) if display else "")

        while child := self.events_box.get_first_child():
            self.events_box.remove(child)
        if not display:
            self.empty_lbl.set_visible(True)
        else:
            self.empty_lbl.set_visible(False)
            for i, e in enumerate(display):
                row = EventRow(e, self._on_event_clicked)
                self.events_box.append(row)
                if i < len(display) - 1:
                    div_inline = Gtk.Box()
                    div_inline.add_css_class("row-divider-inline")
                    div_inline.set_margin_start(20)
                    div_inline.set_margin_end(8)
                    div_inline.set_size_request(-1, 1)
                    self.events_box.append(div_inline)

    def _on_event_clicked(self, event):
        if not event.get("id"):
            event["id"] = str(uuid.uuid4())[:8]
            EventsSource._save_all(self._events)
        self._open_editor(event=event)

    def _on_new_event(self, *a):
        self._open_editor(default_date=self._selected)

    def _open_editor(self, event=None, default_date=None):
        editor = EventEditor(self.app, event=event, default_date=default_date)
        editor.connect("saved", lambda *a: self._kick_refresh())
        editor.connect("deleted", lambda *a: self._kick_refresh())
        editor.present()

    def _on_key(self, c, keyval, *a):
        if keyval == Gdk.KEY_Escape:
            self.hide_popup()
            return True
        if keyval == Gdk.KEY_Left:
            self._shift_month(-1)
            return True
        if keyval == Gdk.KEY_Right:
            self._shift_month(1)
            return True
        if keyval == Gdk.KEY_Home:
            self._on_today()
            return True
        return False

    def show_popup(self):
        close_other_popups("nothing-calendar")
        self._kick_refresh()
        self.set_visible(True)
        self.present()
        self.set_opacity(0.0)
        fade_in(self, duration_ms=180)

    def hide_popup(self):
        fade_out(self, duration_ms=140, on_done=lambda: self.set_visible(False))

    def toggle_popup(self):
        if self.get_visible():
            self.hide_popup()
        else:
            self.show_popup()


