    def __init__(self):
        super().__init__(
            application_id="tech.nothing.calendar",
            flags=Gio.ApplicationFlags.HANDLES_COMMAND_LINE,
        )
        self.window = None
        for opt, short, desc in [
            ("toggle", "t", "Toggle popup"),
            ("show", "s", "Show popup"),
            ("hide", "h", "Hide popup"),
            ("new", "n", "Open new event dialog"),
            ("daemon", "d", "Run as daemon"),
            ("quit", "q", "Quit"),
        ]:
            self.add_main_option(
                opt, ord(short), GLib.OptionFlags.NONE, GLib.OptionArg.NONE, desc, None
            )

    def do_startup(self):
        Adw.Application.do_startup(self)
        Adw.StyleManager.get_default().set_color_scheme(Adw.ColorScheme.FORCE_DARK)
        install_css(extra_css=self.EXTRA_CSS)
        self.window = NothingCalendarWindow(self)
        self.hold()

    def do_command_line(self, cmdline):
        opts = cmdline.get_options_dict().end().unpack()
        if "quit" in opts:
            self.quit()
            return 0
        if "new" in opts:
            self.window.show_popup()
            GLib.timeout_add(100, lambda: (self.window._on_new_event(), False)[1])
            return 0
        if "hide" in opts:
            self.window.hide_popup()
        elif "toggle" in opts:
            self.window.toggle_popup()
        elif "show" in opts:
            self.window.show_popup()
        elif "daemon" in opts:
            pass
        else:
            self.window.toggle_popup()
        return 0

    def do_activate(self):
        if self.window:
            self.window.toggle_popup()


if __name__ == "__main__":
    EVENTS_FILE.parent.mkdir(parents=True, exist_ok=True)
    app = NothingCalendarApp()
    sys.exit(app.run(sys.argv))
