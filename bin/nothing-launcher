        background-color: rgba(255, 255, 255, 0.04);
    }
    .empty-label-clean {
        font-family: "JetBrains Mono", monospace;
        font-weight: 600;
        font-size: 10px;
        color: rgba(255, 255, 255, 0.25);
        letter-spacing: 2px;
    }

    /* Toast — inline failure indicator */
    .toast-clean {
        font-family: "JetBrains Mono", monospace;
        font-weight: 700;
        font-size: 9px;
        color: #FF2D2D;
        background-color: rgba(255, 45, 45, 0.08);
        border: 1px solid rgba(255, 45, 45, 0.30);
        border-radius: 10px;
        padding: 10px 14px;
        letter-spacing: 1.5px;
    }

    /* Search card — unified background, single border */
    .search-card {
        background-color: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 14px;
        transition: border-color 120ms ease, background-color 120ms ease;
    }
    .search-card:focus-within {
        border-color: rgba(255, 45, 45, 0.40);
        background-color: rgba(255, 255, 255, 0.06);
    }

    /* Entry inside search card — fully transparent, no own frame */
    .search-entry-clean,
    .search-entry-clean text,
    .search-entry-clean > text {
        background: transparent;
        background-color: transparent;
        background-image: none;
        color: #FFFFFF;
        font-family: "Inter", sans-serif;
        font-size: 14px;
        font-weight: 500;
        padding: 0 14px 0 0;
        border: none;
        outline: none;
        box-shadow: none;
        caret-color: #FF2D2D;
        letter-spacing: 0.1px;
        min-height: 46px;
    }
    .search-entry-clean:focus,
    .search-entry-clean:focus-within,
    .search-entry-clean text:focus {
        outline: none;
        box-shadow: none;
        background: transparent;
        background-color: transparent;
    }
    .search-entry-clean placeholder,
    .search-entry-clean text placeholder {
        color: rgba(255, 255, 255, 0.30);
    }
    .search-entry-clean selection {
        background-color: rgba(255, 45, 45, 0.35);
        color: #FFFFFF;
    }
    /* App rows — flat, no internal background */

    .app-row {
        background: transparent;
        background-color: transparent;
        padding: 0;
        border-radius: 10px;
        transition: background-color 120ms ease;
    }
    .app-row.hover {
        background-color: rgba(255, 255, 255, 0.04);
    }
    .app-row.selected {
        background-color: rgba(255, 45, 45, 0.08);
    }

    .row-name {
        font-family: "Inter", sans-serif;
        font-weight: 600;
        font-size: 14px;
        color: #FFFFFF;
        letter-spacing: 0.1px;
    }
    .row-secondary {
        font-family: "Inter", sans-serif;
        font-weight: 400;
        font-size: 11px;
        color: rgba(255, 255, 255, 0.45);
        letter-spacing: 0.1px;
    }
    .row-mac {
        font-family: "JetBrains Mono", monospace;
        font-weight: 700;
        font-size: 8px;
        color: #FF2D2D;
        letter-spacing: 1.5px;
    }
    .row-chevron {
        font-family: "Inter", sans-serif;
        font-weight: 400;
        font-size: 18px;
        color: rgba(255, 255, 255, 0.25);
        min-width: 14px;
    }
    .app-row.selected .row-chevron {
        color: #FF2D2D;
    }
    .app-row.hover .row-chevron {
        color: rgba(255, 255, 255, 0.55);
    }

    /* Hide scrollbar */
    .list-scroller scrollbar,
    .list-scroller scrollbar slider {
        opacity: 0;
        min-width: 0;
        min-height: 0;
        background: transparent;
    }
    .list-scroller undershoot,
    .list-scroller overshoot {
        background: none;
        box-shadow: none;
    }
    """

    def __init__(self):
        super().__init__(
            application_id="tech.nothing.launcher",
            flags=Gio.ApplicationFlags.HANDLES_COMMAND_LINE,
        )
        self.window = None
        for opt, short, desc in [
            ("toggle", "t", "Toggle popup"),
            ("show", "s", "Show popup"),
            ("hide", "h", "Hide popup"),
            ("daemon", "d", "Run as daemon"),
            ("quit", "q", "Quit"),
        ]:
            self.add_main_option(
                opt, ord(short), GLib.OptionFlags.NONE, GLib.OptionArg.NONE, desc, None
            )

    def do_startup(self):
        Adw.Application.do_startup(self)
        Adw.StyleManager.get_default().set_color_scheme(Adw.ColorScheme.FORCE_DARK)
        install_css(extra_css=self.EXTRA_CSS)
        self.window = NothingLauncherWindow(self)
        self.hold()

    def do_command_line(self, cmdline):
        opts = cmdline.get_options_dict().end().unpack()
        if "quit" in opts:
            self.quit()
            return 0
        if "hide" in opts:
            self.window.hide_popup()
        elif "show" in opts:
            self.window.show_popup()
        elif "toggle" in opts:
            self.window.toggle_popup()
        elif "daemon" in opts:
            pass
        else:
            self.window.toggle_popup()
        return 0

    def do_activate(self):
        if self.window:
            self.window.toggle_popup()


if __name__ == "__main__":
    app = NothingLauncherApp()
    sys.exit(app.run(sys.argv))
